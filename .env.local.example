# Anthropic API key — required for live agent runs.
# Get one at https://console.anthropic.com
# Without this set, agents fall back to a deterministic stub that still
# demonstrates the architecture but doesn't call Claude.
ANTHROPIC_API_KEY=sk-ant-...

# Default models (optional — overrides hardcoded defaults).
# Cheap tier (filtering, classification): claude-haiku-4-5
# Reasoning tier (negotiation, complex outreach): claude-sonnet-4-6
ANTHROPIC_MODEL_CHEAP=claude-haiku-4-5
ANTHROPIC_MODEL_SMART=claude-sonnet-4-6
