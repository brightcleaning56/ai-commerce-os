# Anthropic API key — required for live agent runs.
# Get one at https://console.anthropic.com
# Without this set, agents fall back to a deterministic stub that still
# demonstrates the architecture but doesn't call Claude.
ANTHROPIC_API_KEY=sk-ant-...

# Default models (optional — overrides hardcoded defaults).
# Cheap tier (filtering, classification): claude-haiku-4-5
# Reasoning tier (negotiation, complex outreach): claude-sonnet-4-6
ANTHROPIC_MODEL_CHEAP=claude-haiku-4-5
ANTHROPIC_MODEL_SMART=claude-sonnet-4-6

# Cron secret — required in production to authenticate Vercel cron requests.
# Generate one with: openssl rand -hex 32
# Set the same value in Vercel via: vercel env add CRON_SECRET production
CRON_SECRET=

# Cron kill-switch — set to "false" to pause the auto-pipeline without redeploying.
# Anything else (including unset) means cron is enabled.
CRON_ENABLED=true

# ── Email send (optional) ───────────────────────────────────────────────────
# Without any provider token below, drafts that are "Sent" land in a simulated
# state — no network call, no real delivery — and the UI shows "(simulated)".
# Sign up at https://postmarkapp.com (or https://resend.com), add a server,
# verify your sending domain, then paste the token here.
#
# IMPORTANT — safety guards (please read):
# 1. EMAIL_TEST_RECIPIENT redirects every send to a single address. Use this
#    in staging so you don't accidentally email fake/unverified buyer addresses.
# 2. Even with a token, real sends only happen when EMAIL_LIVE=true is set.
#    Without EMAIL_LIVE=true, sends still go through the provider but are
#    redirected to EMAIL_TEST_RECIPIENT (or fall back to simulated).
POSTMARK_TOKEN=
# Or use Resend instead:
# RESEND_TOKEN=

EMAIL_FROM=outreach@yourdomain.com
EMAIL_FROM_NAME=AVYN Wholesale
EMAIL_TEST_RECIPIENT=
# Set to "true" to send to real buyer addresses. Default off for safety.
EMAIL_LIVE=false

# ── Inbound webhook (Postmark) ──────────────────────────────────────────────
# Postmark forwards real buyer replies to /api/webhooks/postmark/inbound and
# the route auto-dispatches them to the Negotiation Agent.
# In Postmark dashboard: Servers → your server → Inbound stream → Settings
#   - Webhook URL: https://YOUR-DOMAIN/api/webhooks/postmark/inbound
#   - (recommended) Basic Auth: set username + password and mirror them here.
# Without these env vars, the webhook accepts unauthenticated calls — fine
# for local testing through ngrok, but set them in production.
POSTMARK_INBOUND_USER=
POSTMARK_INBOUND_PASSWORD=

# ── Public app origin (optional) ────────────────────────────────────────────
# Used to build absolute URLs for share links + webhook payloads. Falls back
# to req.nextUrl.origin if unset, which is correct in dev + most Vercel setups.
NEXT_PUBLIC_APP_ORIGIN=

# ── Share-link first-view webhook (optional) ───────────────────────────────
# When set, the system POSTs to this URL the FIRST time each share link is
# opened. Subsequent opens don't re-fire (use the /share-activity feed for
# real-time polling).
#
# Body (JSON):
#   { event:"share.first_view", ts, pipelineId, linkLabel, linkToken, scope,
#     viewer:{ip,userAgent,referer}, dashboardUrl }
#
# If SHARE_FIRSTVIEW_WEBHOOK_SECRET is set, the body is HMAC-SHA256 signed
# and the signature is sent in the X-AICOS-Signature header (sha256=<hex>).
# Recommended: use a Slack incoming-webhook URL, or your own ingest endpoint.
SHARE_FIRSTVIEW_WEBHOOK_URL=
SHARE_FIRSTVIEW_WEBHOOK_SECRET=


# ── Voice / phone calls (optional) ─────────────────────────────────────────
# Used by /tasks call-session drawer and (future) AI outbound calling.
#
# Recommended provider: Vapi (https://vapi.ai). Single vendor for both
# operator browser calling AND AI-driven outbound calls. Anthropic-native,
# uses your existing Twilio number, ~$0.05/min platform fee + LLM costs.
#
# Alternatives:
#   - VOICE_PROVIDER=twilio  → operator-only browser dialer via Twilio
#                              Voice JS SDK. Cheapest (~$0.0085/min outbound)
#                              but you build the AI loop separately.
#   - VOICE_PROVIDER=bland   → AI-first, $0.09/min all-in. Standalone infra.
#
# Without VOICE_PROVIDER set, /tasks falls back to tel: links (opens the
# device dialer). The call-session drawer still works -- timer, outcome,
# notes, attempts log -- just no in-browser voice.
VOICE_PROVIDER=

# Vapi (when VOICE_PROVIDER=vapi)
# Get the private key + assistant id at https://dashboard.vapi.ai
# Phone number id is the Vapi-managed (or Twilio-imported) number
# you'll dial from.
VAPI_PRIVATE_KEY=
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=

# Twilio Voice (when VOICE_PROVIDER=twilio)
# Reuses TWILIO_ACCOUNT_SID + TWILIO_AUTH_TOKEN from the SMS section above.
# TWIML_APP_SID is the Voice TwiML app SID (Twilio Console → Voice → Apps).
# Required for the Voice JS SDK to authenticate browser calls.
TWILIO_TWIML_APP_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=

# Bland (when VOICE_PROVIDER=bland)
BLAND_API_KEY=
